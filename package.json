{
	"name": "bpservers",
	"private": true,
	"version": "0.3.0",
	"type": "module",
	"scripts": {
		"check": "npm run lint",
		"dev": "vite",
		"build": "npm run type-check && vite build",
		"format": "prettier . --write",
		"format:check": "prettier . --check",
		"lint": "eslint src",
		"preview": "vite preview",
		"prepare": "husky",
		"type-check": "vue-tsc -b",
		"validate": "npm run format:check && npm run check && npm run build"
	},
	"dependencies": {
		"vue": "^3.5.32"
	},
	"devDependencies": {
		"@types/node": "^24.12.2",
		"@vitejs/plugin-vue": "^6.0.6",
		"@vue/eslint-config-typescript": "^14.7.0",
		"@vue/tsconfig": "^0.9.1",
		"eslint": "^10.3.0",
		"eslint-plugin-vue": "^10.9.0",
		"husky": "^9.1.7",
		"prettier": "^3.8.3",
		"typescript": "~6.0.2",
		"vite": "^8.0.10",
		"vue-tsc": "^3.2.7"
	}
}
